# The pipeline calls the real Devin API. Without a key + org it fails fast.
# Required — from your Devin organization
DEVIN_API_KEY=
DEVIN_ORG_ID=

# Repo Devin investigates and opens the PR against.
# Use a fork you own (Devin needs write access via the GitHub app).
TARGET_REPO=cognition-demo/superset

# Optional — only powers the dashboard's "Trigger upstream sync" button
# (workflow_dispatch). The local run auto-dispatches a sample incident without it.
# Needs Actions write on TARGET_REPO.
GITHUB_TOKEN=

# Optional — shared secret to authenticate the GitHub Action webhook
WEBHOOK_SECRET=

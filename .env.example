# "replay" runs off pre-recorded fixtures — no Devin API key needed (default)
# "live" calls the real Devin API
PIPELINE_MODE=replay

# Required for live mode only
DEVIN_API_KEY=

# Optional: verify GitHub webhook signatures
GITHUB_WEBHOOK_SECRET=

# Fork repo (Devin will open PRs here)
SUPERSET_FORK_REPO=cognition-demo/superset
